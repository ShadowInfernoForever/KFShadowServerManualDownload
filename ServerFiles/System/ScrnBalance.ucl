Weapon=(ClassName=ScrnBalance.ScrnBoomStick,PickupClassName=ScrnBalance.ScrnBoomStickPickup,AttachmentClassName=KFMod.BoomStickAttachment,FriendlyName=ScrnBalance.ScrnBoomStick.ItemName,Description=ScrnBalance.ScrnBoomStick.Description,FallbackName="Ash's Boomstick",FallbackDesc="This is my BOOMstick (c) Ash, Evil Dead - Army of Darkness, 1992.|Has been used through the centuries to hunt down Demons, Aliens and Zombies. Now it's time for the ZEDs.|Can shoot from one or two barrels simultaneousely. Single shell reload is avaliable.")
