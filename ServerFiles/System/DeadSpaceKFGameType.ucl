Game=(ClassName=DeadSpaceKFGameType.DeadSpaceKFGameType,GameName=DeadSpaceKFGameType.DeadSpaceKFGameType.GameName,TeamGame=1,GameAcronym=DS:KF,MapPrefix=KF,Screenshot=DeadSpaceHUD.GUI.DeadSpaceGametype,MapListClassName=KFMod.KFMapList,Description=DeadSpaceKFGameType.DeadSpaceKFGameType.Description,FallbackName="Dead Space :: Killing Floor",FallbackDesc="Dead Space is set in 2508. Earth has been through an extinction-level event, caused by rapacious and unsustainable use of resources. The remaining humans realized that the only way to gain the resources to survive would be to search new planets for resources. That's where the Concordance Extraction Corporation comes in. At a time of near-desperation, the CEC invented the ship that would eventually save all of humanity: The USG Ishimura.")
Mutator=(ClassName=DeadSpaceKFGameType.MutDeadSpaceWeapons,GroupName=KF-MutDeadSpaceWeapons,IconMaterialName=MutatorArt.nosym,FriendlyName=DeadSpaceKFGameType.MutDeadSpaceWeapons.FriendlyName,Description=DeadSpaceKFGameType.MutDeadSpaceWeapons.Description,FriendlyName=DeadSpaceKFGameType.MutDeadSpaceWeapons.FriendlyName,FallbackName="Starting Guns DeadSpace",FallbackDesc="Replaces starting weapons")
Weapon=(ClassName=DeadSpaceKFGameType.PlasmaCutter,PickupClassName=DeadSpaceKFGameType.PlasmaCutterPickup,AttachmentClassName=DeadSpaceKFGameType.PlasmaCutterAttachment,FriendlyName=DeadSpaceKFGameType.PlasmaCutter.ItemName,Description=DeadSpaceKFGameType.PlasmaCutter.Description,FallbackName="Plasma Cutter",FallbackDesc="Isaac Clarke's weapon of choice in the Dead Space series.")
Weapon=(ClassName=DeadSpaceKFGameType.PulseRifle,PickupClassName=DeadSpaceKFGameType.PulseRiflePickup,AttachmentClassName=DeadSpaceKFGameType.PulseRifleAttachment,FriendlyName=DeadSpaceKFGameType.PulseRifle.ItemName,Description=DeadSpaceKFGameType.PulseRifle.Description,FallbackName="PulseRifle",FallbackDesc="A military grade automatic rifle. Can be fired in semi-auto or full auto firemodes and comes equipped with a scope for increased accuracy.")